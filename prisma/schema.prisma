generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum EventSource {
  TICKETMASTER
  VISIT_JALISCO
  SUPERBOLETOS
  C3_STAGE
  FORO_INDEPENDENCIA
  FUNTICKET
  ARENA_GUADALAJARA
  ETICKET
  KINGTICKET
}

enum AdmissionType {
  FREE
  PAID
  UNKNOWN
}

model Venue {
  id        String   @id @default(cuid())
  name      String
  city      String
  createdAt DateTime @default(now())
  events    Event[]

  @@unique([name, city])
  @@index([city])
}

model Artist {
  id            String               @id @default(cuid())
  name          String               @unique
  imageUrl      String?
  createdAt     DateTime             @default(now())
  events        EventArtist[]
  subscriptions ArtistSubscription[]
}

model Event {
  id            String        @id @default(cuid())
  externalId    String
  title         String
  description   String?
  eventDate     DateTime
  imageUrl      String?
  source        EventSource
  sourceUrl     String?
  admissionType AdmissionType @default(UNKNOWN)
  venueId       String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  venue         Venue         @relation(fields: [venueId], references: [id])
  artists       EventArtist[]
  likes         EventLike[]

  @@unique([source, externalId])
  @@index([eventDate])
  @@index([venueId])
  @@index([source])
  @@index([admissionType])
}

model EventLike {
  id          String   @id @default(cuid())
  eventId     String
  visitorHash String
  createdAt   DateTime @default(now())
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, visitorHash])
  @@index([eventId])
  @@index([createdAt])
}

model EventArtist {
  eventId  String
  artistId String
  event    Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  artist   Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@id([eventId, artistId])
  @@index([artistId])
}

model ArtistSubscription {
  id        String   @id @default(cuid())
  artistId  String
  email     String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  artist    Artist   @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@unique([artistId, email])
  @@index([artistId])
  @@index([email])
  @@index([active])
}
